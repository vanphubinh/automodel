## Local development environment for `apps/api`
##
## Railway best practice:
## - Set these as Railway Variables in the dashboard for production.
## - Keep a local `.env` file for development only (it is gitignored).

# Bind address for the HTTP server.
# Use 127.0.0.1 for local-only, or 0.0.0.0 when running in containers.
HOST=127.0.0.1

# Port for the HTTP server.
PORT=8080

# Logging verbosity (tracing-subscriber EnvFilter).
# Examples: info, debug, trace
RUST_LOG=info

# Capture stack backtraces on rootcause Reports (dev/staging).
# Defaults to on in debug builds, off in release unless set to 1 or true.
# ROOTCAUSE_ENABLE_BACKTRACE=1
# When enabled, optional collector options: leafs, full_paths
# ROOTCAUSE_BACKTRACE=leafs

# Database connection string (SQLx / Postgres).
DATABASE_URL=postgres://antran@localhost:5432/automodel